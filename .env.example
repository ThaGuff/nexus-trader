# ─── NEXUS TRADER · ENVIRONMENT CONFIG ───────────────────────────────────────
# Copy this to .env and fill in your values
# Railway: set these as environment variables in your service settings

# ── Anthropic (required for AI decisions) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── CoinGecko (required for market data) ──────────────────────────────────────
COINGECKO_API_KEY=CG-your-key-here

# ── Coinbase Advanced Trade (required for live trading) ───────────────────────
# Get from: coinbase.com/settings/api → Create new API key → Advanced Trade
# Permissions needed: View, Trade
COINBASE_API_KEY=organizations/xxx/apiKeys/xxx
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nyour-key\n-----END EC PRIVATE KEY-----

# ── Trading Mode ──────────────────────────────────────────────────────────────
# PAPER = simulate trades (no real money), LIVE = real trades on Coinbase
TRADING_MODE=PAPER

# ── Capital Settings ──────────────────────────────────────────────────────────
STARTING_BALANCE=100
MAX_TRADE_USD=20
MAX_POSITION_PCT=0.35
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.08
MAX_DRAWDOWN_PCT=0.20

# ── Cycle Settings ────────────────────────────────────────────────────────────
# How often the bot runs analysis (seconds)
CYCLE_INTERVAL_SECONDS=60

# ── Dashboard ─────────────────────────────────────────────────────────────────
PORT=3000
DASHBOARD_SECRET=change-this-to-a-random-string

# ── Notifications (optional) ──────────────────────────────────────────────────
# Set to enable trade notifications via webhook (e.g. Discord)
DISCORD_WEBHOOK_URL=
