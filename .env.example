# ─── NEXUS TRADER v2.1 · ENVIRONMENT CONFIG ──────────────────────────────────

# ── AI Engine (Gemini Flash — FREE) ──────────────────────────────────────────
# Get free key: aistudio.google.com → Get API Key → Create API Key
GEMINI_API_KEY=AIza-your-key-here

# ── Market Data (Binance public API — no key needed) ─────────────────────────
# No key required — Binance public API is used automatically

# ── Trading Mode ──────────────────────────────────────────────────────────────
TRADING_MODE=PAPER

# ── Coinbase (only needed for LIVE mode) ─────────────────────────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ── Capital Settings ──────────────────────────────────────────────────────────
STARTING_BALANCE=100
MAX_TRADE_USD=20
MAX_POSITION_PCT=0.35
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.08
MAX_DRAWDOWN_PCT=0.20

# ── Leverage ──────────────────────────────────────────────────────────────────
LEVERAGE_ENABLED=false
MAX_LEVERAGE=5

# ── Bot Settings ──────────────────────────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=60
PORT=3000
DASHBOARD_SECRET=nexus-secret-2024

# ── Notifications (optional) ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
